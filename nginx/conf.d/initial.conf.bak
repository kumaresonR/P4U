# ── USE THIS FOR FIRST-TIME SSL SETUP ──
# Rename this to default.conf temporarily before getting SSL cert
# After SSL cert is obtained, switch back to the original default.conf

server {
    listen 80;
    server_name planext4u.com www.planext4u.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location /api/ {
        proxy_pass http://app:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }
}
