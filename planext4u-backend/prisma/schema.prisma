generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Master / Geo ─────────────────────────────────────────────────────────────

model State {
  id         String   @id @default(uuid())
  name       String
  status     String   @default("active")
  created_at DateTime @default(now())

  districts  District[]

  @@map("states")
}

model District {
  id         String   @id @default(uuid())
  name       String
  state_id   String
  status     String   @default("active")
  created_at DateTime @default(now())

  state      State    @relation(fields: [state_id], references: [id])

  @@map("districts")
}

model City {
  id         String   @id
  name       String
  state      String
  status     String   @default("active")
  area_count Int      @default(0)
  created_at DateTime @default(now())

  areas          Area[]
  customers      Customer[]
  vendors        Vendor[]
  serviceVendors ServiceVendor[]
  properties     Property[]

  @@map("cities")
}

model Area {
  id         String   @id
  name       String
  city_id    String
  city_name  String   @default("")
  pincode    String   @default("")
  status     String   @default("active")
  created_at DateTime @default(now())

  city           City          @relation(fields: [city_id], references: [id])
  customers      Customer[]
  vendors        Vendor[]
  serviceVendors ServiceVendor[]
  properties     Property[]

  @@map("areas")
}

model Occupation {
  id             String   @id
  name           String
  status         String   @default("active")
  customer_count Int      @default(0)
  created_at     DateTime @default(now())

  @@map("occupations")
}

// ─── Auth / Users ─────────────────────────────────────────────────────────────

model Profile {
  id         String   @id @default(uuid())
  name       String   @default("")
  email      String   @default("")
  mobile     String?  @default("")
  avatar_url String?  @default("")
  created_at DateTime @default(now())

  @@map("profiles")
}

model Customer {
  id                   String    @id @default(uuid())
  name                 String
  mobile               String    @default("")
  email                String?   @unique
  password_hash        String?
  avatar               String?   @default("")
  city_id              String?
  area_id              String?
  latitude             Float     @default(0)
  longitude            Float     @default(0)
  wallet_points        Int       @default(0)
  referral_code        String    @unique @default("")
  referred_by          String?
  status               String    @default("active")
  occupation           String?
  dob                  DateTime? @db.Date
  gender               String?   @default("Male")
  about                String?   @default("")
  profile_photo        String?   @default("")
  kyc_status           String?   @default("not_started")
  profile_completeness Int       @default(0)
  email_verified       Boolean   @default(false)
  fcm_tokens           String[]  @default([])
  created_at           DateTime  @default(now())

  city               City?             @relation(fields: [city_id], references: [id])
  area               Area?             @relation(fields: [area_id], references: [id])
  addresses          CustomerAddress[]
  orders             Order[]
  pointsTransactions PointsTransaction[]
  classifieds        ClassifiedAd[]
  properties         Property[]
  savedSearches      SavedSearch[]
  rentPayments       RentPayment[]
  socialProfile      SocialProfile?
  kycDocuments       KycDocument[]
  supportTickets     SupportTicket[]
  userDevices        UserDevice[]
  wishlistItems        WishlistItem[]
  cartItems            CartItem[]
  notifications        Notification[]
  propertyMessages     PropertyMessage[] @relation("PropertyMessageSender")
  referralsMade        Referral[]  @relation("ReferrerCustomer")
  referralsReceived    Referral[]  @relation("RefereeCustomer")
  serviceBookings      ServiceBooking[]
  reviews              Review[]

  @@map("customers")
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customer_id  String
  label        String   @default("Home")
  type         String   @default("home")
  address_line String
  city         String   @default("")
  pincode      String   @default("")
  is_default   Boolean  @default(false)
  latitude     Float    @default(0)
  longitude    Float    @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  customer     Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("customer_addresses")
}

model KycDocument {
  id               String   @id @default(uuid())
  user_id          String
  document_type    String   @default("aadhaar")
  document_number  String   @default("")
  front_image_url  String   @default("")
  back_image_url   String   @default("")
  status           String   @default("not_submitted")
  rejection_reason String   @default("")
  admin_notes      String   @default("")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  customer         Customer @relation(fields: [user_id], references: [id])

  @@map("kyc_documents")
}

model UserDevice {
  id          String   @id @default(uuid())
  customer_id String
  fcm_token   String
  device_type String   @default("android")
  device_id   String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("user_devices")
}

model UserRole {
  id          String   @id @default(uuid())
  user_id     String
  role        String   @default("customer")
  created_at  DateTime @default(now())

  @@map("user_roles")
}

// ─── Vendors ──────────────────────────────────────────────────────────────────

model Vendor {
  id               String   @id @default(uuid())
  name             String
  business_name    String   @default("")
  email            String   @unique
  mobile           String   @unique
  password_hash    String?
  avatar           String?  @default("")
  category_id      String?
  plan_id          String?
  city_id          String?
  area_id          String?
  address          String?  @default("")
  latitude         Float?   @default(0)
  longitude        Float?   @default(0)
  commission_rate  Float    @default(10)
  rating           Float    @default(0)
  total_products   Int      @default(0)
  total_orders     Int      @default(0)
  total_revenue    Float    @default(0)
  gst_number          String?  @default("")
  pan_number          String?  @default("")
  kyc_status          String?  @default("pending")
  status              String   @default("pending")
  rejection_reason    String?  @default("")
  membership          String   @default("basic")
  plan_payment_status String   @default("unpaid")
  plan_transaction_id String?  @default("")
  shop_photo_url      String?  @default("")
  fcm_tokens          String[] @default([])
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  plan        VendorPlan?       @relation(fields: [plan_id], references: [id])
  category    Category?         @relation(fields: [category_id], references: [id])
  city        City?             @relation(fields: [city_id], references: [id])
  area        Area?             @relation(fields: [area_id], references: [id])
  products    Product[]
  services    Service[]
  orders      Order[]
  settlements Settlement[]
  bankAccount VendorBankAccount?
  mediaFiles  MediaLibrary[]

  @@map("vendors")
}

model VendorPlan {
  id              String   @id
  name            String
  commission_rate Float    @default(10)
  max_products    Int?
  max_services    Int?
  features        Json?
  price           Float    @default(0)
  duration_days   Int      @default(30)
  status          String   @default("active")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  vendors         Vendor[]
  serviceVendors  ServiceVendor[]

  @@map("vendor_plans")
}

model VendorBankAccount {
  id             String   @id @default(uuid())
  vendor_id      String   @unique
  bank_name      String   @default("")
  account_number String   @default("")
  ifsc_code      String   @default("")
  upi_id         String?  @default("")
  is_verified    Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  vendor         Vendor   @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@map("vendor_bank_accounts")
}

model VendorApplication {
  id          String   @id @default(uuid())
  name        String
  business_name String
  email       String
  mobile      String
  category_id String?
  city_id     String?
  area_id     String?
  documents   Json?
  status      String   @default("pending")
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("vendor_applications")
}

model ServiceVendor {
  id               String   @id @default(uuid())
  name             String
  business_name    String   @default("")
  email            String   @unique
  mobile           String   @unique
  password_hash    String?
  avatar           String?  @default("")
  category_id      String?
  plan_id          String?
  city_id          String?
  area_id          String?
  address          String?  @default("")
  service_area     String?  @default("")
  latitude         Float?   @default(0)
  longitude        Float?   @default(0)
  commission_rate  Float    @default(10)
  rating           Float    @default(0)
  total_services   Int      @default(0)
  total_orders     Int      @default(0)
  total_revenue    Float    @default(0)
  gst_number       String?  @default("")
  pan_number       String?  @default("")
  status           String   @default("pending")
  fcm_tokens       String[] @default([])
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  plan       VendorPlan?      @relation(fields: [plan_id], references: [id])
  category   ServiceCategory? @relation(fields: [category_id], references: [id])
  city       City?            @relation(fields: [city_id], references: [id])
  area       Area?            @relation(fields: [area_id], references: [id])
  mediaFiles MediaLibrary[]

  @@map("service_vendors")
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id                   String   @id
  name                 String
  parent_id            String?
  image                String   @default("")
  status               String   @default("active")
  count                Int      @default(0)
  banner_image         String?  @default("")
  icon                 String?  @default("")
  is_trending          Boolean  @default(false)
  description          String?  @default("")
  is_emergency         Boolean  @default(false)
  verification_status  String   @default("unverified")
  commission_rate      Float?
  promotion_banner_url String?
  promotion_title      String?
  promotion_active     Boolean  @default(false)
  created_at           DateTime @default(now())

  parent   Category?  @relation("CategorySelf", fields: [parent_id], references: [id])
  children Category[] @relation("CategorySelf")
  products Product[]
  vendors  Vendor[]

  @@map("categories")
}

model ServiceCategory {
  id          String   @id
  name        String
  parent_id   String?
  image       String?  @default("")
  icon        String?  @default("")
  description String?  @default("")
  status      String   @default("active")
  created_at  DateTime @default(now())

  parent         ServiceCategory?  @relation("ServiceCategorySelf", fields: [parent_id], references: [id])
  children       ServiceCategory[] @relation("ServiceCategorySelf")
  services       Service[]
  serviceVendors ServiceVendor[]

  @@map("service_categories")
}

model ClassifiedCategory {
  id   Int    @id @default(autoincrement())
  name String

  @@map("classified_categories")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id                     String   @id @default(uuid())
  vendor_id              String
  category_id            String?
  subcategory_id         String?
  subcategory_name       String?  @default("")
  title                  String
  description            String   @default("") @db.Text
  short_description      String?  @default("") @db.Text
  long_description       String?  @default("") @db.Text
  price                  Float    @default(0)
  tax                    Float    @default(0)
  discount               Float    @default(0)
  discount_type          String?  @default("fixed")
  max_points_redeemable  Int      @default(0)
  max_redemption_percentage Float?
  status                 String   @default("active")
  vendor_name            String?  @default("")
  category_name          String?  @default("")
  emoji                  String?  @default("")
  image                  String?  @default("")
  thumbnail_image        String?  @default("")
  banner_image           String?  @default("")
  images                 Json     @default("[]")
  youtube_video_url      String?  @default("")
  rating                 Float    @default(0)
  reviews                Int      @default(0)
  stock                  Int      @default(0)
  sales                  Int      @default(0)
  manage_stock           Boolean  @default(false)
  stock_status           String   @default("in_stock")
  rejection_reason       String?  @default("")
  inactivation_reason    String?  @default("")
  product_attributes     Json     @default("[]")
  tax_slab_id            String?
  is_available           Boolean  @default(true)
  duration_hours         Int      @default(0)
  duration_minutes       Int      @default(0)
  promise_p4u            String?  @default("") @db.Text
  helpline_number        String?  @default("")
  product_type           String   @default("simple")
  sku                    String?
  slug                   String?  @unique
  meta_title             String?  @default("")
  meta_description       String?  @default("")
  weight                 Float    @default(0)
  dimensions             Json     @default("{}")
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  vendor       Vendor    @relation(fields: [vendor_id], references: [id])
  category     Category? @relation(fields: [category_id], references: [id])
  variants     ProductVariant[]
  attributeMap ProductAttributeMap[]
  inventoryLog InventoryLog[]
  cartItems    CartItem[]
  wishlist     WishlistItem[]

  @@map("products")
}

model ProductVariant {
  id                 String   @id @default(uuid())
  product_id         String
  sku                String?
  price              Float    @default(0)
  compare_at_price   Float    @default(0)
  stock_quantity     Int      @default(0)
  stock_status       String   @default("in_stock")
  weight             Float    @default(0)
  dimensions         Json     @default("{}")
  variant_attributes Json     @default("{}")
  image_url          String?  @default("")
  is_active          Boolean  @default(true)
  sort_order         Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  product            Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  images             ProductVariantImage[]

  @@map("product_variants")
}

model ProductVariantImage {
  id         String   @id @default(uuid())
  variant_id String
  image_url  String
  sort_order Int      @default(0)
  is_primary Boolean  @default(false)
  created_at DateTime @default(now())

  variant    ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("product_variant_images")
}

model ProductAttribute {
  id             String   @id @default(uuid())
  name           String
  attribute_type String   @default("select")
  sort_order     Int      @default(0)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  values         ProductAttributeValue[]
  attributeMap   ProductAttributeMap[]

  @@map("product_attributes")
}

model ProductAttributeValue {
  id            String   @id @default(uuid())
  attribute_id  String
  value         String
  sort_order    Int      @default(0)
  hex_color     String   @default("")
  display_label String   @default("")
  created_at    DateTime @default(now())

  attribute     ProductAttribute @relation(fields: [attribute_id], references: [id], onDelete: Cascade)

  @@map("product_attribute_values")
}

model ProductAttributeMap {
  id           String   @id @default(uuid())
  product_id   String
  attribute_id String
  created_at   DateTime @default(now())

  product      Product          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  attribute    ProductAttribute @relation(fields: [attribute_id], references: [id], onDelete: Cascade)

  @@map("product_attribute_map")
}

model InventoryLog {
  id           String   @id @default(uuid())
  product_id   String
  variant_id   String?
  change_qty   Int      @default(0)
  previous_qty Int      @default(0)
  new_qty      Int      @default(0)
  reason       String   @default("")
  performed_by String?
  created_at   DateTime @default(now())

  product      Product  @relation(fields: [product_id], references: [id])

  @@map("inventory_log")
}

// ─── Services ─────────────────────────────────────────────────────────────────

model Service {
  id                    String   @id @default(uuid())
  vendor_id             String
  category_id           String?
  title                 String
  description           String   @default("") @db.Text
  price                 Float    @default(0)
  tax                   Float    @default(0)
  discount              Float    @default(0)
  max_points_redeemable Int      @default(0)
  status                String   @default("active")
  is_available          Boolean  @default(true)
  vendor_name           String?  @default("")
  category_name         String?  @default("")
  emoji                 String?  @default("")
  image                 String?  @default("")
  images                Json     @default("[]")
  rating                Float    @default(0)
  reviews               Int      @default(0)
  duration              String?  @default("")
  service_area          String?  @default("")
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  vendor          Vendor           @relation(fields: [vendor_id], references: [id])
  category        ServiceCategory? @relation(fields: [category_id], references: [id])
  serviceBookings ServiceBooking[]

  @@map("services")
}

// ─── Tax ─────────────────────────────────────────────────────────────────────

model TaxConfig {
  id         String   @id @default(uuid())
  name       String
  rate       Float    @default(0)
  type       String   @default("GST")
  status     String   @default("active")
  applied_to String?  @default("")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("tax_config")
}

model TaxSlab {
  id          String   @id @default(uuid())
  name        String
  rate        Float    @default(0)
  hsn_code    String?  @default("")
  description String?  @default("")
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("tax_slabs")
}

// ─── Orders & Settlements ─────────────────────────────────────────────────────

model Order {
  id                   String    @id @default(uuid())
  customer_id          String
  vendor_id            String?
  subtotal             Float     @default(0)
  tax_amount           Float     @default(0)
  discount_amount      Float     @default(0)
  points_used          Int       @default(0)
  points_discount      Float     @default(0)
  total                Float     @default(0)
  status               String    @default("placed")
  payment_status       String    @default("pending")
  razorpay_order_id    String?
  razorpay_payment_id  String?
  customer_name        String?   @default("")
  vendor_name          String?   @default("")
  items_json           Json      @default("[]")
  delivery_address     Json?
  notes                String?   @db.Text
  platform_fee         Float     @default(0)
  gst_on_platform_fee  Float     @default(0)
  payment_reference_id String?
  delivery_rating      Int?
  rating_comment       String?
  rated_at             DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  customer   Customer    @relation(fields: [customer_id], references: [id])
  vendor     Vendor?     @relation(fields: [vendor_id], references: [id])
  orderItems OrderItem[]
  settlement Settlement?

  @@map("orders")
}

model Settlement {
  id          String    @id @default(uuid())
  order_id    String    @unique
  vendor_id   String
  vendor_name String?   @default("")
  amount      Float     @default(0)
  commission  Float     @default(0)
  net_amount  Float     @default(0)
  status      String    @default("pending")
  settled_at  DateTime?
  created_at  DateTime  @default(now())

  order       Order     @relation(fields: [order_id], references: [id])
  vendor      Vendor    @relation(fields: [vendor_id], references: [id])

  @@map("settlements")
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                  String   @id @default(uuid())
  order_id            String
  customer_id         String
  razorpay_order_id   String?  @unique
  razorpay_payment_id String?
  razorpay_signature  String?
  amount              Float    @default(0)
  currency            String   @default("INR")
  status              String   @default("created")
  method              String?
  refund_id           String?
  refund_amount       Float?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@map("payments")
}

// ─── Loyalty & Referrals ──────────────────────────────────────────────────────

model PointsTransaction {
  id                       String    @id @default(uuid())
  user_id                  String
  order_id                 String?
  /// Set when type is social_post_like_received — for reversal on unlike
  social_post_id           String?
  social_liker_profile_id  String?
  type                     String
  points                   Int       @default(0)
  description              String    @default("")
  user_name                String?   @default("")
  expires_at               DateTime?
  is_expired               Boolean   @default(false)
  created_at               DateTime    @default(now())

  customer    Customer  @relation(fields: [user_id], references: [id])

  @@index([user_id, social_post_id, social_liker_profile_id])
  @@map("points_transactions")
}

model Referral {
  id                String    @id @default(uuid())
  referrer_id       String
  referee_id        String    @unique
  status            String    @default("pending")
  points_awarded    Int       @default(0)
  referrer_name     String?   @default("")
  referee_name      String?   @default("")
  cooling_until     DateTime?
  first_order_placed Boolean  @default(false)
  bonus_credited    Boolean   @default(false)
  created_at        DateTime  @default(now())

  referrer          Customer  @relation("ReferrerCustomer", fields: [referrer_id], references: [id])
  referee           Customer  @relation("RefereeCustomer", fields: [referee_id], references: [id])

  @@map("referrals")
}

// ─── Classifieds ─────────────────────────────────────────────────────────────

model ClassifiedAd {
  id          String   @id @default(uuid())
  title       String
  description String   @default("") @db.Text
  price       Float    @default(0)
  category    String   @default("")
  city        String   @default("")
  area        String   @default("")
  images      Json     @default("[]")
  user_id     String
  user_name   String?  @default("")
  status      String   @default("pending")
  created_at  DateTime @default(now())

  user        Customer @relation(fields: [user_id], references: [id])

  @@map("classified_ads")
}

// ─── Properties ───────────────────────────────────────────────────────────────

model Property {
  id               String   @id @default(uuid())
  user_id          String
  title            String
  description      String?  @db.Text
  property_type    String
  transaction_type String
  price            Float    @default(0)
  area_sqft        Float?
  bedrooms         Int?
  bathrooms        Int?
  floors           Int?
  floor_number     Int?
  total_floors     Int?
  furnishing       String?
  facing           String?
  age_years        Int?
  city_id          String?
  area_id          String?
  locality_id      String?
  locality         String?
  address          String?  @db.Text
  latitude         Float?
  longitude        Float?
  images           Json     @default("[]")
  video_url        String?
  amenities        Json     @default("[]")
  is_featured      Boolean  @default(false)
  status           String   @default("pending")
  views_count      Int      @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user      Customer          @relation(fields: [user_id], references: [id])
  city      City?             @relation(fields: [city_id], references: [id])
  area      Area?             @relation(fields: [area_id], references: [id])
  messages  PropertyMessage[]
  bookmarks PropertyBookmark[]
  enquiries PropertyEnquiry[]
  visits    PropertyVisit[]
  reports   PropertyReport[]

  @@map("properties")
}

model PropertyLocality {
  id         String   @id @default(uuid())
  name       String
  city_id    String?
  area_id    String?
  status     String   @default("active")
  created_at DateTime @default(now())

  @@map("property_localities")
}

model PropertyAmenity {
  id         String   @id @default(uuid())
  name       String
  icon       String?
  category   String?
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  @@map("property_amenities")
}

model PropertyPlan {
  id          String   @id @default(uuid())
  name        String
