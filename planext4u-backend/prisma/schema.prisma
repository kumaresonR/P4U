// ─── Social ───────────────────────────────────────────────────────────────────

model SocialProfile {
  id              String   @id @default(uuid())
  customer_id     String   @unique
  username        String   @unique
  bio             String?  @db.Text
  website         String?
  avatar          String?
  cover_image     String?
  is_creator      Boolean  @default(false)
  is_verified     Boolean  @default(false)
  followers_count Int      @default(0)
  following_count Int      @default(0)
  posts_count     Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  customer        Customer        @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  posts           SocialPost[]
  stories         SocialStory[]
  following       SocialFollow[]  @relation("FollowerProfile")
  followers       SocialFollow[]  @relation("FollowingProfile")
  sentMessages    SocialMessage[] @relation("MessageSender")
  receivedMessages SocialMessage[] @relation("MessageReceiver")
  notifications   SocialNotification[]
  highlights      SocialHighlight[]
  bookmarks       SocialBookmark[]

  @@map("social_profiles")
}

model SocialPost {
  id             String   @id @default(uuid())
  profile_id     String
  caption        String?  @db.Text
  media_urls     Json     @default("[]")
  post_type      String   @default("photo")
  likes_count    Int      @default(0)
  comments_count Int      @default(0)
  shares_count   Int      @default(0)
  views_count    Int      @default(0)
  is_pinned      Boolean  @default(false)
  location       String?
  tags           Json     @default("[]")
  hashtags       Json     @default("[]")
  status         String   @default("active")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  profile        SocialProfile   @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  likes          SocialLike[]
  comments       SocialComment[]
  bookmarks      SocialBookmark[]

  @@map("social_posts")
}

model SocialStory {
  id         String   @id @default(uuid())
  profile_id String
  media_url  String
  media_type String   @default("image")
  duration   Int      @default(5)
  expires_at DateTime
  views_count Int     @default(0)
  created_at DateTime @default(now())

  profile    SocialProfile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  views      SocialStoryView[]

  @@map("social_stories")
}

model SocialStoryView {
  id         String   @id @default(uuid())
  story_id   String
  viewer_id  String
  created_at DateTime @default(now())

  story      SocialStory @relation(fields: [story_id], references: [id], onDelete: Cascade)

  @@unique([story_id, viewer_id])
  @@map("social_story_views")
}

model SocialLike {
  id         String   @id @default(uuid())
  post_id    String
  profile_id String
  created_at DateTime @default(now())

  post       SocialPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, profile_id])
  @@map("social_likes")
}

model SocialComment {
  id          String   @id @default(uuid())
  post_id     String
  profile_id  String
  parent_id   String?
  content     String   @db.Text
  likes_count Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  post        SocialPost      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  parent      SocialComment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies     SocialComment[] @relation("CommentReplies")
  commentLikes SocialCommentLike[]

  @@map("social_comments")
}

model SocialCommentLike {
  id         String   @id @default(uuid())
  comment_id String
  profile_id String
  created_at DateTime @default(now())

  comment    SocialComment @relation(fields: [comment_id], references: [id], onDelete: Cascade)

  @@unique([comment_id, profile_id])
  @@map("social_comment_likes")
}

model SocialFollow {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())

  follower     SocialProfile @relation("FollowerProfile",  fields: [follower_id],  references: [id], onDelete: Cascade)
  following    SocialProfile @relation("FollowingProfile", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@map("social_follows")
}

model SocialConversation {
  id           String   @id @default(uuid())
  participant1 String
  participant2 String
  last_message String?  @db.Text
  last_msg_at  DateTime?
  created_at   DateTime @default(now())

  messages     SocialMessage[]

  @@unique([participant1, participant2])
  @@map("social_conversations")
}

model SocialMessage {
  id              String   @id @default(uuid())
  conversation_id String
  sender_id       String
  receiver_id     String
  message         String   @db.Text
  media_url       String?
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  conversation    SocialConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          SocialProfile      @relation("MessageSender",   fields: [sender_id],   references: [id])
  receiver        SocialProfile      @relation("MessageReceiver", fields: [receiver_id], references: [id])

  @@map("social_messages")
}

model SocialNotification {
  id          String   @id @default(uuid())
  profile_id  String
  type        String
  title       String
  body        String   @db.Text
  data        Json?
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  profile     SocialProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("social_notifications")
}

model SocialHighlight {
  id          String   @id @default(uuid())
  profile_id  String
  title       String
  cover_image String?
  story_ids   Json     @default("[]")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  profile     SocialProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("social_highlights")
}

model SocialBookmark {
  id         String   @id @default(uuid())
  profile_id String
  post_id    String
  created_at DateTime @default(now())

  profile    SocialProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  post       SocialPost    @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, post_id])
  @@map("social_bookmarks")
}

model SocialHashtag {
  id          String   @id @default(uuid())
  tag         String   @unique
