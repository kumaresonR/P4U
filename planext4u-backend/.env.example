# ─── App ─────────────────────────────
NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1
FRONTEND_URLS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ─── Database ────────────────────────
DATABASE_URL=postgresql://planext:YOUR_DB_PASSWORD@localhost:5432/planext4u

# ─── Redis ───────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── JWT (each secret must be ≥32 characters) ─────────────────────────────
JWT_ACCESS_SECRET=replace_with_access_secret_min_32_characters
JWT_REFRESH_SECRET=replace_with_refresh_secret_min_32_characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Email ───────────────────────────
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=your_email
SMTP_PASS=your_password
SMTP_FROM="App <your_email>"

# ─── Razorpay ────────────────────────
RAZORPAY_KEY_ID=your_key
RAZORPAY_KEY_SECRET=your_secret

# ─── Firebase ────────────────────────
FIREBASE_PROJECT_ID=your_project
FIREBASE_API_KEY=your_key
FIREBASE_CLIENT_EMAIL=your_email
FIREBASE_PRIVATE_KEY="your_private_key"

# ─── GCS ─────────────────────────────
GCS_PROJECT_ID=your_project
GCS_BUCKET=your_bucket

# ─── Maps ────────────────────────────
GOOGLE_MAPS_API_KEY=your_key

# ─── Loyalty (optional; app has defaults) ────────────────────────────
WELCOME_BONUS_POINTS=200
REFERRAL_BONUS_POINTS=100
ORDER_REWARD_PERCENTAGE=2
SOCIAL_LIKE_RECEIVER_POINTS=1
